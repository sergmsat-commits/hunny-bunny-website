  <style>
  
  <style>
.fade-in {
  opacity: 0;
  transform: translateY(40px);
  transition: all 0.8s ease;
}

.fade-in.visible {
  opacity: 1;
  transform: translateY(0);
}

/* Отзывы */
.review-card {
  transition: transform 0.3s ease;
}

.review-card:hover {
  transform: scale(1.05);
}

/* Instagram / WhatsApp / Telegram */
.instagram-float {
  animation: pulse 2s infinite;
}

@keyframes pulse {
  0% { transform: scale(1); }
  50% { transform: scale(1.08); }
  100% { transform: scale(1); }
}

/* Зайчик */
.bunny-logo {
  animation: bunnyJump 3s infinite;
}

@keyframes bunnyJump {
  0% { transform: translateY(0); }
  10% { transform: translateY(-8px); }
  20% { transform: translateY(0); }
  100% { transform: translateY(0); }
}

/* Подсказки для кнопок */
.tooltip {
  position: relative;
}

.tooltip::before {
  content: attr(data-tooltip);
  position: absolute;
  right: 85px;
  top: 50%;
  transform: translateY(-50%);
  background: #333;
  color: white;
  padding: 8px 12px;
  border-radius: 8px;
  font-size: 14px;
  white-space: nowrap;
  opacity: 0;
  visibility: hidden;
  transition: 0.3s;
  pointer-events: none;
}

.tooltip:hover::before {
  opacity: 1;
  visibility: visible;
}

/* Карточки курсов */
.course-card {
  transition: all 0.3s ease;
}

.course-card:hover {
  transform: translateY(-10px);
}
/* Преимущества */
.feature-card {
  background: white;
  width: 320px;
  padding: 25px;
  border-radius: 18px;
  text-align: center;
  font-size: 18px;
  font-weight: bold;
  box-shadow: 0 4px 15px rgba(0,0,0,0.08);
  transition: all 0.3s ease;
}

.feature-card:hover {
  transform: translateY(-8px);
  box-shadow: 0 10px 25px rgba(139,92,246,0.25);
}
</style>

